{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ERP Venture",
  "version": "1.0.0",
  "identifier": "com.venture.erp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "security": {
      "csp": "default-src 'self' customprotocol: asset:; connect-src 'self' ipc: http://ipc.localhost https://api.venturerp.com https://dev-api.venturerp.com http://localhost:* ws://localhost:*; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; script-src 'self'"
    },
    "windows": [
      {
        "title": "ERP Venture Desktop",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "minWidth": 1024,
        "minHeight": 680,
        "label": "main",
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQzMjAzRERDQTI0OUI5NjkKUldScHVVbWkzRDBnUXhoRWp2ZFA2STlRWVpzeGlMTE5pYXpjams1aVc2dWlmU1gwMjJYRE1kVzEK",
      "endpoints": [
        "https://github.com/FelipePn10/app-venture/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
