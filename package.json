{
  "name": "erp-desktop-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:demo": "vite --mode demo",
    "build": "tsc --noEmit && vite build",
    "build:demo": "tsc --noEmit && vite build --mode demo",
    "preview": "vite preview",
    "preview:demo": "vite preview --mode demo",
    "lint": "eslint . --ext ts,tsx --max-warnings 0",
    "tauri:dev": "tauri dev",
    "tauri:dev:demo": "tauri dev --config src-tauri/tauri.demo.conf.json",
    "tauri:build": "tauri build",
    "tauri:build:demo": "tauri build --config src-tauri/tauri.demo.conf.json",
    "doctor:package": "node scripts/verify-package-json.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.51.1",
    "@tauri-apps/api": "^2.10.1",
    "axios": "^1.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "playwright-core": "^1.60.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
